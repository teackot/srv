#!/usr/bin/env bash

set -uexo pipefail

sed -i 's|#LockLayering.*|LockLayering=true|' /etc/rpm-ostreed.conf

dnf -y install zram-generator-defaults

dnf -y install firewalld fail2ban

dnf -y install tmux vim fish

# to fend off lazy botnets probing the 22nd port
semanage port -a -t ssh_port_t -p tcp 1022
